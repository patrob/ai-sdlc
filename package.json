{
  "name": "ai-sdlc",
  "version": "0.3.1-alpha.2",
  "description": "Agent-first SDLC workflow manager with pluggable AI providers",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "ai-sdlc": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:coverage": "vitest run --coverage --config vitest.coverage.config.ts",
    "test:watch": "vitest",
    "lint": "tsc --noEmit && eslint . --max-warnings 0",
    "deadcode": "knip",
    "prepublishOnly": "npm run lint && npm run build && npm test"
  },
  "keywords": [
    "sdlc",
    "agent",
    "workflow",
    "claude",
    "ai"
  ],
  "author": "Patrick Robinson",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/patrob/ai-sdlc.git"
  },
  "bugs": {
    "url": "https://github.com/patrob/ai-sdlc/issues"
  },
  "homepage": "https://github.com/patrob/ai-sdlc#readme",
  "files": [
    "dist",
    "templates",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@earendil-works/pi-agent-core": "^0.79.1",
    "@earendil-works/pi-ai": "^0.79.1",
    "chalk": "^5.3.0",
    "chokidar": "^4.0.0",
    "cli-table3": "^0.6.5",
    "commander": "^12.0.0",
    "glob": "^11.0.0",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.2.0",
    "ora": "^8.0.0",
    "pino": "^10.3.1",
    "proper-lockfile": "^4.1.2",
    "string-width": "^8.2.1",
    "write-file-atomic": "^5.0.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.19.42",
    "@types/proper-lockfile": "^4.1.4",
    "@types/write-file-atomic": "^4.0.3",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.4.1",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "knip": "^6.16.1",
    "tsx": "^4.22.4",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=22.19.0"
  }
}
